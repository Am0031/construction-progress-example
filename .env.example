# Copy this file to .env and fill in your own key (never commit .env).
#
# The Assistant page works with no setup at all, using a free, keyless
# public model (pollinations.ai) — that's what the deployed demo runs on.
# It's rate-limited to about one message every 15 seconds and can be
# lower quality, so for a faster/better local demo, set a Groq key below:
# get a free key at https://console.groq.com/keys.
VITE_GROQ_API_KEY=

# Optional: override the default Groq model (see console.groq.com/docs/models
# for currently available models — Groq's free-tier lineup changes over time).
# VITE_GROQ_MODEL=llama-3.3-70b-versatile
